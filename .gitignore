venv
.venv
.idea
__pycache__
pytest.cache
data

# Environment variables (содержит токены и секреты)
.env
.env.*
.env.local
.env.production
.env.staging
!.env.example

# Конфигурации с чувствительными данными
secrets.py
*_secrets.py
config_local.py
src/config/*_local.py

# Логи (могут содержать чувствительные данные)
*.log
logs/
*.log.*

# Скриншоты и видео из тестов (могут содержать персональные данные)
screenshots/
videos/
test-results/
diagnostics/

# Сертификаты и ключи
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.keystore

# Файлы с токенами
tokens.json
credentials.json
auth.json

# Дампы БД
*.sql
*.dump
*.bak

# Временные файлы с данными
temp_data/
tmp/
*.tmp

# Allure reports
allure-results/
allure-report/
